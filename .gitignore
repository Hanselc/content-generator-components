# comfy-ui: cloned fresh by setup.sh — only track user content
/tools/comfy-ui/*
!/tools/comfy-ui/user/
/tools/comfy-ui/user/__manager/
/tools/comfy-ui/user/*.db
/tools/comfy-ui/user/*.db.lock
/tools/comfy-ui/user/*.log
!/tools/comfy-ui/user/default/
/tools/comfy-ui/user/default/workflows/*.lock

# custom_nodes: ignored by default; add !/tools/comfy-ui/custom_nodes/<your_node> when you create one
/tools/comfy-ui/custom_nodes/

# movie-py local
/tools/movie-py/.env
/tools/movie-py/examples/

# Python
__pycache__/
*.py[cod]
*.pyc
.venv/
venv*/

# Conda workspace envs (created by setup.sh, not versioned)
.conda-envs/

# OS / editors
.DS_Store
.idea/
.vscode/