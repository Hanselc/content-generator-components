# comfy-ui: cloned fresh by setup.sh — only track user content
/comfy-ui/*
!/comfy-ui/user/
/comfy-ui/user/__manager/
/comfy-ui/user/*.db
/comfy-ui/user/*.db.lock
/comfy-ui/user/*.log
!/comfy-ui/user/default/
/comfy-ui/user/default/workflows/*.lock

# custom_nodes: ignored by default; add !/comfy-ui/custom_nodes/<your_node> when you create one
/comfy-ui/custom_nodes/

# movie-py local
/movie-py/.env
/movie-py/examples/

# Python
__pycache__/
*.py[cod]
*.pyc
.venv/
venv*/

# Conda workspace envs (created by setup.sh, not versioned)
.conda-envs/

# OS / editors
.DS_Store
.idea/
.vscode/