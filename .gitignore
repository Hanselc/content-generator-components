# comfy-ui: cloned fresh by setup.sh — only track workflows
/tools/comfy-ui/*
!/tools/comfy-ui/user/
/tools/comfy-ui/user/*
!/tools/comfy-ui/user/default/
/tools/comfy-ui/user/default/*
!/tools/comfy-ui/user/default/workflows/

# movie-py local
/tools/movie-py/.env
/tools/movie-py/examples/

# Python
__pycache__/
*.py[cod]
*.pyc
.venv/
venv*/

# Conda workspace envs (created by setup.sh, not versioned)
.conda-envs/

# OS / editors
.DS_Store
.idea/
.vscode/