type":"BOOLEAN","widget":{"name":"enable_proj_lora"},"link":null}],"outputs":[{"localized_name":"Train Config","name":"Train Config","type":"*","links":[21]}],"properties":{"Node name for S&R":"VoxCPM2_TrainConfig","cnr_id":"ComfyUI-VoxCPM2","ver":"7875a8a36a531b7efef8cac96dc74001d3cb5895","aux_id":"Saganaki22/ComfyUI-VoxCPM"},"widgets_values":[0.0001,32,16,0,100,1,8192,44100,0.01,true,true,false]},{"id":4,"type":"PreviewAudio","pos":[2833.4701916602266,3156.1698380050702],"size":[594.8125,116],"flags":{},"order":9,"mode":0,"inputs":[{"localized_name":"audio","name":"audio","type":"AUDIO","link":32},{"localized_name":"audioUI","name":"audioUI","type":"AUDIO_UI","widget":{"name":"audioUI"},"link":null}],"outputs":[{"localized_name":"audio","name":"audio","type":"AUDIO","links":null}],"properties":{"Node name for S&R":"PreviewAudio","cnr_id":"comfy-core","ver":"0.17.0"},"widgets_values":[]},{"id":23,"type":"MarkdownNote","pos":[1447.7268830861558,3366.9208408121362],"size":[501.65625,1848.203125],"flags":{},"order":3,"mode":0,"inputs":[],"outputs":[],"title":"|","properties":{},"widgets_values":["# VoxCPM2\n\n  ## Auto-Download\n\n  **Models auto-download on first run** - no manual setup needed!\n\n  | Model | VRAM | Size |\n  |-------|------|------|\n  | VoxCPM2 (bf16) | ~8GB | ~4GB |\n\n  ---\n\n  ## Manual Download\n\n  | File | Size | Link |\n  |------|------|------|\n  | VoxCPM2 | ~4GB | [Download](https://huggingface.co/openbmb/VoxCPM2) |\n\n<br>\n\n```\n  Place in:\n  ComfyUI/models/tts/VoxCPM/\n  └── VoxCPM2/\n      ├── config.json\n      ├── model.safetensors\n      ├── audiovae.pth\n      ├── tokenizer.json\n      └── ...\n```\n<br>\n\n  ---\n\n  ## Voice Design (no reference audio needed)\n\n  Put a natural-language description in `voice_description`:\n\n  > A young woman, gentle and sweet voice\n\n  > An old man with a gravelly, slow voice\n\n  > A child, excited and energetic\n\n  The description is automatically wrapped in parentheses and prepended to your text.\n\n  ---\n\n  ## Voice Cloning Modes\n\n  | Mode | Inputs | Description |\n  |------|--------|-------------|\n  | **Controllable** | reference audio only | Clones timbre, optional style control via voice_description |\n  | **Ultimate** | reference audio + prompt_text | Audio-continuation cloning, highest fidelity, every nuance reproduced\n  \n\n  ---\n\n  ## LoRA Training\n\n  Train custom voice LoRA adapters directly in ComfyUI using the training nodes.\n\n  **[Full LoRA Training Guide](https://github.com/Saganaki22/ComfyUI-VoxCPM2/blob/main/docs/readme-lora-training.md)**\n\n  ---\n\n  ## Supported Languages (30)\n\n  Arabic, Burmese, Chinese, Danish, Dutch, English, Finnish, French, German, Greek, Hebrew, Hindi, Indonesian, Italian,\n  Japanese, Khmer, Korean, Lao, Malay, Norwegian, Polish, Portuguese, Russian, Spanish, Swahili, Swedish, Tagalog, Thai,\n   Turkish, Vietnamese\n\n  Chinese Dialects: Sichuan, Cantonese, Wu, Northeastern, Henan, Shaanxi, Shandong, Tianjin, Southern Min\n\n  ---\n\n  ## Links\n\n  - Original [VoxCPM](https://github.com/OpenBMB/VoxCPM)\n  - Model [VoxCPM2](https://huggingface.co/openbmb/VoxCPM2)\n  - Based on [ComfyUI-VoxCPM](https://github.com/wildminder/ComfyUI-VoxCPM) by\n  [@wildminder](https://github.com/wildminder)\n  - Issues [Report Bug](https://github.com/Saganaki22/ComfyUI-VoxCPM2/issues)"],"color":"#c09430","bgcolor":"rgba(24,24,27,.9)"},{"id":26,"type":"VoxCPM2_Clone","pos":[2284.432033412338,3378.764078746633],"size":[400,776],"flags":{},"order":8,"mode":0,"inputs":[{"localized_name":"reference_audio","name":"reference_audio","type":"AUDIO","link":34},{"localized_name":"model_name","name":"model_name","type":"COMBO","widget":{"name":"model_name"},"link":null},{"localized_name":"lora_name","name":"lora_name","type":"COMBO","widget":{"name":"lora_name"},"link":null},{"localized_name":"voice_description","name":"voice_description","type":"STRING","widget":{"name":"voice_description"},"link":null},{"localized_name":"