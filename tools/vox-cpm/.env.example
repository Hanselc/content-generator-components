# Base host path of the n8n workspace. n8n passes only the folder name
# (e.g. "2026-06-23/134443"); the server resolves it against this path.
WORKSPACE_BASE_PATH=~/Documents/projects/n8n/content-generator/workspace

# Server port (default 8788)
PORT=8788

# VoxCPM model identifier (HuggingFace hub name or local path)
MODEL_NAME=openbmb/VoxCPM2

# Runtime device: auto | cpu | mps | cuda | cuda:N
VOXCPM_DEVICE=auto

# Load the denoiser model for cleaning noisy reference audio (true/false)
VOXCPM_LOAD_DENOISER=false