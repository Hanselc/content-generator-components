# Workspace base path. Request path fields (output_path) are
# workspace-relative and resolved against this.
WORKSPACE_BASE_PATH=/home/hansel/documents/dev/projects/n8n

# Directory holding per-voice subfolders (references/<referenceId>/).
# Defaults to <script_dir>/references. Set this to host references elsewhere
# without moving files into the tool directory.
# REFERENCES_DIR=/path/to/references

# Server port (default 8788)
PORT=8788

# VoxCPM model identifier (HuggingFace hub name or local path).
# One model serves all voices; only the per-voice prompt/reference latents differ.
MODEL_NAME=openbmb/VoxCPM2

# Runtime device: auto | cpu | mps | cuda | cuda:N
VOXCPM_DEVICE=auto

# CFG guidance scale (1.0 = half the DiT passes / less VRAM; 2.0 = default).
VOXCPM_CFG_VALUE=2.0

# Max generated audio tokens per segment (lower = less VRAM). Default 2000.
VOXCPM_MAX_GENERATE_LENGTH=2000

# Sampling temperature. Default 1.0.
VOXCPM_TEMPERATURE=1.0

# Max characters per text segment before splitting at punctuation/clause
# boundaries (lower = more stable generation, more segments). Default 800.
VOXCPM_MAX_SEGMENT_CHARS=800

# Engine init knobs (the 4 passed to from_pretrained).
VOXCPM_GPU_MEMORY_UTILIZATION=0.90
VOXCPM_MAX_NUM_SEQS=1
VOXCPM_MAX_NUM_BATCHED_TOKENS=8192