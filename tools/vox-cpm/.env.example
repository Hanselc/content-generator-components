# Base host path of the n8n workspace. n8n passes only the folder name
# (e.g. "2026-06-23/134443"); the server resolves it against this path.
WORKSPACE_BASE_PATH=~/Documents/projects/n8n/content-generator/workspace

# Server port (default 8788)
PORT=8788

# VoxCPM model identifier (HuggingFace hub name or local path)
MODEL_NAME=openbmb/VoxCPM2

# Runtime device: auto | cpu | mps | cuda | cuda:N
VOXCPM_DEVICE=auto

# Load the denoiser model for cleaning noisy reference audio (true/false)
VOXCPM_LOAD_DENOISER=false

# Enable torch.compile acceleration (true/false). Disable on low-VRAM GPUs
# or when serving concurrent requests (CUDA Graphs are not thread-safe).
VOXCPM_OPTIMIZE=false

# Max generated audio tokens per segment (lower = less VRAM). Default 2000.
VOXCPM_MAX_LEN=2000

# CFG guidance scale (1.0 = half the DiT passes / less VRAM; 2.0 = default).
VOXCPM_CFG_VALUE=2.0

# Diffusion steps (4-30; lower = less VRAM, lower quality). Default 10.
VOXCPM_INFERENCE_TIMESTEPS=10

# Retry abnormally short/long outputs (false = avoid repeated peak-memory spikes).
VOXCPM_RETRY_BADCASE=false

# Max characters per text segment before splitting at punctuation/clause
# boundaries (lower = more stable generation, more segments). Default 200.
VOXCPM_MAX_SEGMENT_CHARS=200