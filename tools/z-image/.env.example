# Base host path of the n8n workspace. n8n passes only the folder name
# (e.g. "2026-06-23/134443"); the server resolves it against this path.
WORKSPACE_BASE_PATH=~/Documents/projects/n8n/content-generator/workspace

# Server port (default 8789)
PORT=8789

# Z-Image model identifier (HuggingFace hub name or local path).
# Use Tongyi-MAI/Z-Image-Turbo for 8-step guidance-free generation, or
# Tongyi-MAI/Z-Image for the 28-50 step CFG-guided foundation model.
MODEL_NAME=Tongyi-MAI/Z-Image-Turbo

# Runtime device: auto | cpu | mps | cuda | cuda:N
ZIMAGE_DEVICE=auto

# Default output dimensions. Total pixel area matters more than aspect;
# 512x512 to 2048x2048 (any aspect) is supported.
ZIMAGE_WIDTH=1024
ZIMAGE_HEIGHT=1024

# Diffusion steps. Turbo: 9 (yields 8 DiT forwards). Z-Image: 28-50.
ZIMAGE_STEPS=9

# CFG guidance scale. Turbo: 0.0 (guidance-free). Z-Image: 3.0-5.0.
ZIMAGE_CFG=0.0

# CPU offload: move model sub-layers to GPU only during their forward pass.
# enable_sequential_cpu_offload() keeps peak VRAM low enough to run the 6B
# DiT on 8 GB cards, at the cost of significant transfer overhead per step.
# Set false for cards with >=16 GB VRAM (the model is kept resident on GPU).
ZIMAGE_CPU_OFFLOAD=false